.emergex/context/
.emergex/evolution.log

# But DO include skills and config:
# .emergex/skills/*.md
# .emergex/config.json

# Lock files (bun.lockb is binary, keep it)
package-lock.json
yarn.lock
.next/
.history/
.bmad/

# Claude worktrees (isolated agent workspaces, never commit)
.claude/worktrees/

# Audio files (too large for git, regenerate with sync-audio.ts)
docs/audio/*.aiff
docs/branch-audio/*.aiff

# UI sample outputs (artifacts belong in emergex-world, not the harness)
benchmarks/ui-samples/
benchmarks/artifacts/

# Ecosystem media (canonical: emergex-world public/media)
/media/

# Local reference clone (nested .git; do not commit)
claude-code/

# Content drafts (belong in ~/Myresumeportfolio/content/)
docs/content/

# Lil EmergeX build artifacts (rebuild with: bun run pet:build)
apps/lil-emergex/build/

# Large media files
*.mp4
*.wav

# Archived media/video/audio directories (moved to emergex-code-archive)
video-emergex-app/
smoke-and-fly/
docs/audio/
docs/branch-audio/

# Session plan dumps
*-plan-location-*.txt
